---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">



    <!-- SECT: Header -->
    <header class="text-[2em] grid place-items-center bg-[url('/path.png')] bg-no-repeat bg-cover h-[400px] relative [text-shadow:4px_4px_5px_theme(colors.default-text),-4px_-4px_5px_theme(colors.default-text),0_4px_5px_theme(colors.default-text),0_-4px_5px_theme(colors.default-text)] rounded-b-[10%] border-b border-default-text shadow-[0_2px_1em] shadow-default-text max-[600px]:h-auto max-[600px]:p-8 max-[600px]:bg-[url('/crowed-of-people.jpg')]">
        <div class="bg-transparent w-[50vw] text-center text-white max-[600px]:w-[75vw] max-[600px]:text-[1.05em]">
            <h1 class="text-4xl font-bold">Contact Us</h1>
        </div>
        <div class="custom-shape-divider-bottom-1709772170 absolute bottom-0 left-0 w-full overflow-hidden leading-[0]">
            <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none" class="relative block w-[calc(100%+1.3px)] h-[44px]">
                <path d="M600,112.77C268.63,112.77,0,65.52,0,7.23V120H1200V7.23C1200,65.52,931.37,112.77,600,112.77Z" class="shape-fill fill-none"></path>
            </svg>
        </div>       
    </header>




    <!-- SECT: Header -->
    <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
            
            <!-- Text Section -->
            <div class="lg:w-1/2 space-y-6 text-left">
                <h2 class="text-4xl font-bold text-default-text">Join Our Intentional Community</h2>
                <div class="text-lg text-default-text space-y-4">
                    <p>
                        Are you ready to take the next step toward a more intentional, self-reliant, and community-focused life? We are looking for like-minded individuals and families who are passionate about building a future founded on truth, tradition, and mutual support.
                    </p>
                    <p>
                        Please fill out the application form to the right. This helps us understand your background, your values, and your reasons for wanting to join Alternative Everything. 
                    </p>
                    <p>
                        Once submitted, our team will review your application and reach out to schedule a conversation. We look forward to hearing from you and potentially welcoming you into our community.
                    </p>
                    <div class="pt-6 border-t border-gray-200">
                        <p class="font-bold">Contact Information:</p>
                        <p>Phone: (816) 575-2798</p>
                        <p>Address: 3100 NW Winchester Rd, Cameron, MO 64429</p>
                    </div>
                </div>
            </div>




            <!-- SECT: Form Section -->
            <div class="lg:w-1/2 w-full">
                <div class="bg-white p-8 md:p-10 rounded-xl shadow-2xl border border-gray-200 text-left">
                    <form action="#" method="POST" class="space-y-6 text-default-text">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="block font-bold text-sm">Name</label>
                                <input type="text" name="name" class="w-full border-b border-gray-300 focus:border-primary outline-none py-1" placeholder="______________________________">
                            </div>
                            <div class="space-y-1">
                                <label class="block font-bold text-sm">Age</label>
                                <input type="text" name="age" class="w-full border-b border-gray-300 focus:border-primary outline-none py-1" placeholder="_____">
                            </div>
                            <div class="space-y-1">
                                <label class="block font-bold text-sm">Sex</label>
                                <input type="text" name="sex" class="w-full border-b border-gray-300 focus:border-primary outline-none py-1" placeholder="__________">
                            </div>
                            <div class="space-y-1">
                                <label class="block font-bold text-sm">Race</label>
                                <input type="text" name="race" class="w-full border-b border-gray-300 focus:border-primary outline-none py-1" placeholder="_________________">
                            </div>
                        </div>

                        <div class="space-y-1">
                            <label class="block font-bold text-sm">How many in your household?</label>
                            <input type="text" name="household_count" class="w-full border-b border-gray-300 focus:border-primary outline-none py-1" placeholder="______________">
                        </div>

                        <div class="space-y-4">
                            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                                <p class="font-bold text-sm">Are you a Christian?</p>
                                <div class="flex space-x-4">
                                    <label class="flex items-center space-x-2 text-sm"><input type="radio" name="christian" value="yes"> <span>Yes</span></label>
                                    <label class="flex items-center space-x-2 text-sm"><input type="radio" name="christian" value="no"> <span>No</span></label>
                                </div>
                            </div>

                            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                                <p class="font-bold text-sm text-balance">Do you believe Joseph Smith was a prophet?</p>
                                <div class="flex space-x-4">
                                    <label class="flex items-center space-x-2 text-sm"><input type="radio" name="joseph_smith" value="yes"> <span>Yes</span></label>
                                    <label class="flex items-center space-x-2 text-sm"><input type="radio" name="joseph_smith" value="no"> <span>No</span></label>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <p class="font-bold text-sm">Are you Red-Pilled, or had some kind of realization that what most people accept as normal, in fact isn’t?</p>
                            <p class="text-xs italic text-secondary">Do you consider yourself “Red-Pilled”, or had some kind of realization about what is real or unreal, true or false?</p>
                            <div class="flex space-x-6">
                                <label class="flex items-center space-x-2 text-sm"><input type="radio" name="red_pilled" value="yes"> <span>Yes</span></label>
                                <label class="flex items-center space-x-2 text-sm"><input type="radio" name="red_pilled" value="no"> <span>No</span></label>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <p class="font-bold text-sm">Who is head of the family?</p>
                            <div class="flex flex-wrap gap-4">
                                <label class="flex items-center space-x-2 text-sm"><input type="radio" name="family_head" value="husband"> <span>Husband</span></label>
                                <label class="flex items-center space-x-2 text-sm"><input type="radio" name="family_head" value="wife"> <span>Wife</span></label>
                                <label class="flex items-center space-x-2 text-sm"><input type="radio" name="family_head" value="mutual"> <span>Mutual</span></label>
                            </div>
                        </div>

                        <div class="space-y-4 pt-4 border-t border-gray-100">
                            <p class="font-bold text-sm">What are your primary reasons for wanting to join an intentional community?</p>
                            <p class="text-xs italic text-secondary mb-2">Please number the options below (1 = most important, 12 = least).</p>
                            
                            <div class="grid grid-cols-1 gap-2">
                                {[
                                    "Creating a healthy, moral culture.",
                                    "Fostering interpersonal relationships.",
                                    "Making a healthy environment for children.",
                                    "Growing or raising your own food.",
                                    "Mutual self-defense.",
                                    "Relocating to a better area.",
                                    "Working with like minded people.",
                                    "Spiritual growth.",
                                    "Outreach, ministry or charity work.",
                                    "Affordable housing.",
                                    "Escaping a coming disaster."
                                ].map((reason) => (
                                    <div class="flex items-center space-x-3">
                                        <input type="number" min="1" max="12" class="w-12 border border-gray-300 rounded p-0.5 text-center text-sm" placeholder="__">
                                        <span class="text-sm">{reason}</span>
                                    </div>
                                ))}
                                <div class="flex flex-col space-y-1">
                                    <div class="flex items-center space-x-3">
                                        <input type="number" min="1" max="12" class="w-12 border border-gray-300 rounded p-0.5 text-center text-sm" placeholder="__">
                                        <span class="text-sm">Other not listed:</span>
                                    </div>
                                    <input type="text" class="w-full border-b border-gray-300 focus:border-primary outline-none py-1 ml-15" placeholder="_______________________________________">
                                </div>
                            </div>
                        </div>

                        <div class="pt-6 text-center">
                            <button type="submit" class="w-full border-2 border-solid border-default-text rounded-[20px] px-[30px] py-[12px] text-lg text-default-text bg-white font-bold hover:bg-[#bad4c2] transition-colors shadow-md">Submit Application</button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- SECT: End: Form -->




        </div>
    </div>
</Layout>
