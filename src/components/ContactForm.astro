---
const reasons = [
    "Creating a healthy, moral culture.",
    "Fostering interpersonal relationships.",
    "Making a healthy environment for children.",
    "Growing or raising your own food.",
    "Mutual self-defense.",
    "Relocating to a better area.",
    "Working with like minded people.",
    "Spiritual growth.",
    "Outreach, ministry or charity work.",
    "Affordable housing.",
    "Escaping a coming disaster.",
    "Other",
];

const traditions = [
    "Non-Denominational",
    "Anabaptist",
    "Anglican",
    "Assemblies of God",
    "Baptist",
    "Bible Church",
    "Catholic",
    "Christian Science",
    "Church of Christ",
    "Eastern Orthodox",
    "Episcopal",
    "Jehovah’s Witnesses",
    "Latter-Day Saints",
    "Lutheran",
    "Mennonite",
    "Messianic",
    "Methodist",
    "Nazarene",
    "Pentecostal",
    "Presbyterian",
    "Reformed",
    "Seventh Day Adventist",
    "United Church of Christ",
    "Other",
];
---

<div class="w-full bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-gray-100 text-left">
    <form
      name="Contact" 
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="flex flex-col gap-8"
      method="post"
      action="/"
    >
      <p class="hidden">
        <label>
          Don’t fill this out:
          <input name="bot-field" />
        </label>
      </p>
      <input type="hidden" name="form-name" value="Contact" />
      
      <!-- Basic Info -->
      <div class="flex flex-col gap-8 w-full">
        <div class="flex flex-col gap-2">
          <div class="text-base font-bold text-gray-700 uppercase tracking-wider">Name</div>
          <input type="text" name="name" required id="name" placeholder="Full Name" class="border-b-2 border-gray-200 focus:border-primary outline-none py-2 text-xl transition-colors bg-white text-black" />
        </div>
        <div class="flex flex-col gap-2">
          <div class="text-base font-bold text-gray-700 uppercase tracking-wider">Age</div>
          <input type="text" name="age" required id="age" placeholder="Age" class="border-b-2 border-gray-200 focus:border-primary outline-none py-2 text-xl transition-colors bg-white text-black w-40" />
        </div>
        <div class="flex flex-col gap-2">
          <div class="text-base font-bold text-gray-700 uppercase tracking-wider">Sex</div>
          <input type="text" name="sex" required id="sex" placeholder="Sex" class="border-b-2 border-gray-200 focus:border-primary outline-none py-2 text-xl transition-colors bg-white text-black w-40" />
        </div>
        <div class="flex flex-col gap-2">
          <div class="text-base font-bold text-gray-700 uppercase tracking-wider">Race</div>
          <input type="text" name="race" required id="race" placeholder="Race" class="border-b-2 border-gray-200 focus:border-primary outline-none py-2 text-xl transition-colors bg-white text-black w-72" />
        </div>
      </div>

      <div class="flex flex-col gap-2 w-full">
        <div class="text-base font-bold text-gray-700 uppercase tracking-wider">How many in your household?</div>
        <input type="text" name="household_count" required id="household_count" placeholder="0" class="border-b-2 border-gray-200 focus:border-primary outline-none py-2 text-xl transition-colors bg-white text-black w-32" />
      </div>

      <!-- Values / Background -->
      <div class="flex flex-col gap-16 text-black border-t border-gray-100 pt-16 w-full">
        <div class="flex flex-col gap-8">
            <div class="text-base font-bold text-gray-700 uppercase tracking-wider">Are you a Christian?</div>
            <div class="flex flex-col gap-6">
                <label class="flex items-center space-x-6 cursor-pointer"><input type="radio" name="christian" value="yes" required class="accent-primary w-8 h-8"> <span class="text-xl">Yes</span></label>
                <label class="flex items-center space-x-6 cursor-pointer"><input type="radio" name="christian" value="no" required class="accent-primary w-8 h-8"> <span class="text-xl">No</span></label>
            </div>
        </div>

        <div class="flex flex-col gap-8">
            <div class="flex flex-col gap-2">
              <div class="text-base font-bold text-gray-700 uppercase tracking-wider">What church tradition do you identify with?</div>
            </div>
            <select name="tradition" required class="border-b-2 border-gray-200 focus:border-primary outline-none py-2 text-xl transition-colors bg-white text-black w-full md:w-96">
                <option value="" disabled selected>Select a tradition</option>
                {traditions.map((tradition) => (
                    <option value={tradition}>{tradition}</option>
                ))}
            </select>
        </div>

        <div class="flex flex-col gap-8">
            <div class="flex flex-col gap-2">
              <div class="text-base font-bold text-gray-700 uppercase tracking-wider">Are you Red-Pilled, or had some kind of realization that what most people accept as normal, in fact isn’t?</div>
            </div>
            <div class="flex flex-col gap-6">
                <label class="flex items-center space-x-6 cursor-pointer"><input type="radio" name="red_pilled" value="yes" required class="accent-primary w-8 h-8"> <span class="text-xl">Yes</span></label>
                <label class="flex items-center space-x-4 cursor-pointer"><input type="radio" name="red_pilled" value="no" required class="accent-primary w-8 h-8"> <span class="text-xl">No</span></label>
            </div>
        </div>

        <div class="flex flex-col gap-8">
            <div class="text-base font-bold text-gray-700 uppercase tracking-wider">Who is head of the family?</div>
            <div class="flex flex-col gap-6">
                <label class="flex items-center space-x-6 cursor-pointer"><input type="radio" name="family_head" value="husband" required class="accent-primary w-8 h-8"> <span class="text-xl">Husband</span></label>
                <label class="flex items-center space-x-6 cursor-pointer"><input type="radio" name="family_head" value="wife" required class="accent-primary w-8 h-8"> <span class="text-xl">Wife</span></label>
                <label class="flex items-center space-x-6 cursor-pointer"><input type="radio" name="family_head" value="mutual" required class="accent-primary w-8 h-8"> <span class="text-xl">Mutual</span></label>
            </div>
        </div>
      </div>

      <!-- Reasons -->
      <div class="flex flex-col gap-10 text-black border-t border-gray-100 pt-10 w-full">
        <div class="flex flex-col gap-2">
            <div class="font-bold text-base text-gray-700 uppercase tracking-wider">Primary reasons for wanting to join?</div>
            <div class="text-sm italic text-secondary uppercase tracking-tight">Number options (1 = most important, 12 = least).</div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-10">
            {reasons.map((reason) => (
                <div class="flex items-center justify-between border-b border-gray-100 pb-3">
                    <span class="text-lg text-gray-700 font-medium">{reason}</span>
                    <input 
                      type="number" 
                      name={`reason_${reason.replace(/\s+/g, '_').replace(/[^\w]/g, '').toLowerCase()}`} 
                      min="1" 
                      max="12" 
                      required
                      class="w-12 border-b-2 border-gray-200 focus:border-primary outline-none p-1 text-center text-lg transition-colors bg-white text-black" 
                      placeholder="-"
                    >
                </div>
            ))}
        </div>

        <div class="flex flex-col gap-4 mt-4">
          <div class="text-base font-bold text-gray-700 uppercase tracking-wider">If you selected "Other" for reasons or tradition, please explain:</div>
          <textarea 
            name="other_explanation" 
            rows="3" 
            class="border-2 border-gray-100 focus:border-primary outline-none p-4 rounded-xl text-lg transition-colors bg-white text-black w-full" 
            placeholder="Provide more detail here..."
          ></textarea>
        </div>
      </div>

      <button
        type="submit"
        class="mt-4 bg-primary hover:bg-opacity-90 text-white rounded-xl py-4 text-xl font-bold shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5"
      >
        Submit Application
      </button>
    </form>
</div>

<style>
  ::placeholder { 
    color: #cbd5e1; 
  }

  .hidden {
    display: none;
  }
</style>
